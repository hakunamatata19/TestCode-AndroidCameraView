<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".DetailActivity">

    <!-- 相机预览容器，TimestampWatermarkView 动态添加至此 -->
    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/controlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- 顶部录制状态条：红点 + 计时 -->
    <LinearLayout
        android:id="@+id/tvRecordingTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_recording_time"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <View
            android:id="@+id/recordingDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/dot_white" />

        <TextView
            android:id="@+id/tvRecordingTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="00:00"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 拖动提示，第一次拖动后自动隐藏 -->
    <TextView
        android:id="@+id/tvDragHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_recording_time"
        android:backgroundTint="@color/overlay_dark"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        android:text="拖动时间戳调整水印位置"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/controlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 底部控制栏 -->
    <FrameLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_control_bar_gradient"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 翻转摄像头 -->
        <ImageButton
            android:id="@+id/btnFlipCamera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="翻转摄像头"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#FFFFFF" />

        <!-- 录制按钮（环形，状态可切换） -->
        <ImageButton
            android:id="@+id/btnRecord"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="center"
            android:background="@drawable/selector_record_button"
            android:contentDescription="录制" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
