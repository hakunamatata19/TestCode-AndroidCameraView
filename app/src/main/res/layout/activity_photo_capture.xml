<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".PhotoCaptureActivity">

    <!-- 相机预览容器 -->
    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/controlBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- 底部控制栏 -->
    <FrameLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_control_bar_gradient"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 翻转摄像头 -->
        <ImageButton
            android:id="@+id/btnFlipCamera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_circle_dark"
            android:contentDescription="翻转摄像头"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="#FFFFFF" />

        <!-- 拍照按钮（圆形大按钮） -->
        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_capture_button"
            android:contentDescription="拍照" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
